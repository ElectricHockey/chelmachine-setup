extends ../layout

mixin team_list(idname)
    select(name=idname)
        option(value='') NO TEAM
        for team in season_teams
            option(value=team._id)=team.team_name

block content
    .red
        h1.red Add Games to Schedule
        p This form will add games to the current season schedule. You can leave fields as NO TEAM if you only want to submit a partial schedule update.
        form(action="/admin/add_games",method="POST",id="add_games_form")
            table.page_width.colorized
                tr
                    th(colspan=2) Season
                tr
                    td(colspan=2) Changing the season will reload the page. You can only add games for one season at a time.
                tr
                    td Season:
                    td
                        select(id="season_id",name="season_id",onChange=`window.location.href="/admin/add_games?season_id="+this.value;`)
                            for season in seasons
                                option(value=season.season_id,selected=query.season_id==season.season_id)=season.label
            br
            table.page_width.colorized
                tr
                    th.left(colspan=2) Common Game Attributes
                
                tr
                    td Year:
                    td
                        select(id="year",name="year")
                            for year in years
                                option(value=year,selected=year==(new Date().getYear()+1900))=year
                tr
                    td Month:
                    td
                        select(id="month",name="month")
                            for month in months
                                option(value=month)=month
                tr
                    td Day:
                    td
                        select(id="day",name="day")
                            for day in days
                                option(value=day)=day
                tr
                    td Time:
                    td
                        select(id="time",name="time")
                            for time in times
                                option(value=time)=time
                tr
                    td Game Type:
                    td
                        select(id="game_type",name="game_type")
                            for game in game_types
                                option(value=game)=game
            br
            table.page_width.colorized
                tr
                    th
                    th Away Team
                    th Home Team
                - var team_entry = 0;
                while team_entry < 20
                    if team_entry > 0 && team_entry % 5 == 0
                        tr
                            th(colspan=3) Break
                    tr
                        td.center #{team_entry+1}.
                        td.center
                            +team_list('away_team')
                        td.center
                            +team_list('home_team')
                    - ++team_entry

            .center
                button(type="submit") Add Games

