extends layout
include ../_visual

block owner_link_content
    p You can set your trade block and view other teams trade blocks here.
    span.red NOTE: This information is confidential and should not be shared outside of team owners.
    form(action=`/front_office/block?idx=${query.idx}`,method='POST')
        input(type='hidden',name='team_id',value=team._id)
        table.page_width.colorized
            tr
                th(colspan=2) #{team.team_name} Trade Block
            tr
                th PLAYER
                th ON BLOCK
            for p in team.roster
                - const user = team.users.find((u)=>u.auth.username==p);
                tr
                    td.half_page_width
                        if user
                            +discord_avatar_small(user)
                            +discord_username(user)
                        else
                            span=p
                    td.center
                        if team.release_block && team.release_block.includes(p)
                            span.red RELEASE PENDING
                        else if active_trade_offer && active_trade_offer.author_players.includes(p)
                            span.red IN TRADE OFFER
                        else if accepted_trade_offer && accepted_trade_offer.offer_players.includes(p)
                            span.red IN ACCEPTED TRADE OFFER
                        else
                            - let allow_block = true;
                            if team.ownership
                                for owner in team.ownership
                                    if owner.discordname === p
                                        - allow_block = false;
                            if allow_block
                                input(type='checkbox',name=p,checked=team.trade_block&&team.trade_block.includes(p))
                            else
                                span.red FRONT OFFICE
            tr
                th(colspan=2)
                    button(type='submit') Update Trade Block
    br
    table.page_width.colorized
        tr
            th(colspan='3') Other Trade Blocks
    for other_team in teams
        if (!team._id.equals(other_team._id))
            if other_team.trade_block && other_team.trade_block.length
                table.page_width.colorized
                    tr
                        th TEAM
                        th CONF
                        th DIV
                    tr
                        td
                            +team_logo(other_team, 'logo_medium')
                        td.center=other_team.conference
                        td.center=other_team.division
                    for player in other_team.trade_block
                        - 
                            const user = other_team.users.find((u)=>u.auth.username==player);
                        if user
                            tr
                                td(colspan=3).center
                                    span
                                        +discord_avatar(user,'logo_small')
                                        +discord_username(user)
            br
